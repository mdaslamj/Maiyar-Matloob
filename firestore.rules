rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isGoogleAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.firebase.sign_in_provider == 'google.com'
        && request.auth.token.email in get(/databases/$(database)/documents/system/config).data.adminEmails;
    }

    match /participants/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isGoogleAdmin();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /assessments/{assessmentId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.schemaVersion is int;
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid) || isGoogleAdmin();
      allow update, delete: if false;
    }

    match /community/implementation/questionAnswers/{questionId} {
      allow read: if isGoogleAdmin();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /community/implementation/sectionAggregates/{sectionId} {
      allow read: if isGoogleAdmin();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /community/implementation/meta {
      allow read: if isGoogleAdmin();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /admin/{document=**} {
      allow read, write: if isGoogleAdmin();
    }

    match /system/config {
      allow read: if isSignedIn();
      allow write: if isGoogleAdmin();
    }

    match /system/versions {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
